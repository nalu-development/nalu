<?xml version="1.0" encoding="utf-8"?>

<nalu:NaluShell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:nalu="https://nalu-development.github.com/nalu/navigation"
                xmlns:pages="clr-namespace:Nalu.Maui.Sample.Pages"
                xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                xmlns:sample="clr-namespace:Nalu.Maui.Sample"
                x:Class="Nalu.Maui.Sample.AppShell">
    <FlyoutItem Route="main"
                FlyoutDisplayOptions="AsMultipleItems"
                Title="Tabs"
                Icon="{FontImageSource Glyph='&#xe88a;'}"
                nalu:NaluShell.TabBarView="{sample:AppShellTabBar}">
        <Tab Title="Pages"
             Route="pages"
             FlyoutDisplayOptions="AsMultipleItems"
             Icon="{FontImageSource Glyph='&#xe88a;'}">
            <ShellContent nalu:Navigation.PageType="pages:OnePage"
                          Title="Page One"
                          Icon="{FontImageSource Glyph='&#xe88a;'}" />
            <ShellContent nalu:Navigation.PageType="pages:SevenPage"
                          Title="Page Seven"
                          Icon="{FontImageSource Glyph='&#xe88b;'}" />
        </Tab>
        <ShellContent nalu:Navigation.PageType="pages:TwoPage"
                      Title="Page Two"
                      Icon="{FontImageSource Glyph='&#xe88e;'}" />
        <ShellContent nalu:Navigation.PageType="pages:EightPage"
                      Title="Page Eight">
            <ShellContent.Icon>
                <x:Binding Source="{RelativeSource Self}"
                                         Path="IsChecked">
                        <x:Binding.Converter>
                                <toolkit:BoolToObjectConverter x:TypeArguments="ImageSource"
                                                             TrueObject="{FontImageSource FontFamily='MaterialFilled', Glyph='&#xe88e;'}"
                                                             FalseObject="{FontImageSource Glyph='&#xe88e;'}"/>
                            </x:Binding.Converter>
                    </x:Binding>
            </ShellContent.Icon>
        </ShellContent>
        <ShellContent nalu:Navigation.PageType="pages:NinePage"
                      Title="Page Nine"
                      Icon="{FontImageSource Glyph='&#xe8b9;'}" />
        <ShellContent nalu:Navigation.PageType="pages:DynamicDataPage"
                      Title="Dynamic Data"
                      Icon="{FontImageSource Glyph='&#xe8ba;'}" />
        <ShellContent nalu:Navigation.PageType="pages:TenPage"
                      Title="Page Ten"
                      Icon="{FontImageSource Glyph='&#xe8ba;'}" />
        <ShellContent nalu:Navigation.PageType="pages:TenCarouselPage"
                      Title="Page Ten Carousel"
                      Icon="{FontImageSource Glyph='&#xe8ba;'}" />
        <ShellContent nalu:Navigation.PageType="pages:ElevenPage"
                      Title="Page Eleven"
                      Icon="{FontImageSource Glyph='&#xe8bb;'}" />
        <ShellContent nalu:Navigation.PageType="pages:GroupedDynamicDataPage"
                      Title="Grouped DynamicData"
                      Icon="{FontImageSource Glyph='&#xe8bc;'}" />
        <ShellContent nalu:Navigation.PageType="pages:ExpanderPage"
                      Title="Expander Page"
                      Icon="{FontImageSource Glyph='&#xe8bd;'}" />
        <ShellContent nalu:Navigation.PageType="pages:TwelvePage"
                      Title="Page Twelve"
                      Icon="{FontImageSource Glyph='&#xe8bc;'}" />
    </FlyoutItem>
    <MenuItem x:Name="CustomMenuItem"
              Text="Hello"
              IconImageSource="{FontImageSource Glyph='&#xe88e;'}"/>
    <ShellContent nalu:Navigation.PageType="pages:FivePage"
                  Title="Page Five"
                  Icon="{FontImageSource Glyph='&#xe88b;'}" />
    <ShellContent nalu:Navigation.PageType="pages:MagnetDemoPage"
                  Title="Magnet Demo"
                  Icon="{FontImageSource Glyph='&#xe88c;'}" />
    <ShellContent nalu:Navigation.PageType="pages:SoftKeyboardManagerPage"
                  Title="Soft Keyboard Manager"
                  Icon="{FontImageSource Glyph='&#xe312;'}" />
</nalu:NaluShell>
