<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:nalu="https://nalu-development.github.com/nalu/layouts"
             x:Class="Nalu.Maui.Sample.Pages.SlideViewPage"
             Title="SlideView Demo">
    <Grid RowDefinitions="Auto,Auto,*"
          Padding="16"
          RowSpacing="12">
        <HorizontalStackLayout Grid.Row="0"
                               Spacing="12">
            <Button Text="Toggle Orientation"
                    Clicked="OnToggleOrientationClicked" />
            <Label VerticalOptions="Center"
                   Text="{Binding Source={x:Reference SlideView}, Path=Orientation}" />
        </HorizontalStackLayout>

        <Label Grid.Row="1"
               FontAttributes="Bold"
               Text="{Binding Source={x:Reference SlideView}, Path=SelectedIndex, StringFormat='SelectedIndex: {0}'}" />

        <Border Grid.Row="2"
                VerticalOptions="Center"
                StrokeShape="RoundRectangle 12"
                BackgroundColor="#F4F4F4"
                Padding="8">
            <nalu:SlideViewBox x:Name="SlideView"
                            SelectedIndex="0"
                            Orientation="Horizontal">
                <Border BackgroundColor="#FFB3B3"
                        StrokeShape="RoundRectangle 8"
                        Margin="8">
                    <VerticalStackLayout Padding="16"
                                         VerticalOptions="Center">
                        <Label Text="Slide 1"
                               FontSize="28"
                               FontAttributes="Bold" />
                        <Label Text="Swipe to test snap and index sync." />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#B3D9FF"
                        StrokeShape="RoundRectangle 8"
                        Margin="8">
                    <VerticalStackLayout Padding="16"
                                         VerticalOptions="Center">
                        <Label Text="Slide 2"
                               FontSize="28"
                               FontAttributes="Bold" />
                        <Label Text="Toggle orientation with the button above." />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#C8F0C8"
                        StrokeShape="RoundRectangle 8"
                        Margin="8">
                    <VerticalStackLayout Padding="16"
                                         VerticalOptions="Center">
                        <Label Text="Slide 3"
                               FontSize="28"
                               FontAttributes="Bold" />
                        <Label Text="SelectedIndex updates while you scroll." />
                    </VerticalStackLayout>
                </Border>
            </nalu:SlideViewBox>
        </Border>
    </Grid>
</ContentPage>

